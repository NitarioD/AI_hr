# Copy to .env.local for `vercel dev`, or set in Vercel Dashboard → Settings → Environment Variables.
# Get a key: https://aistudio.google.com/apikey (no card required on free tier limits)
GEMINI_API_KEY=your_key_here

# Optional: if you see free-tier quota limit:0 for the default model, try e.g. gemini-1.5-flash or gemini-2.5-flash
# GEMINI_MODEL=gemini-1.5-flash
