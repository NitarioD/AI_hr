# Copy to .env.local for `vercel dev`, or set in Vercel Dashboard → Settings → Environment Variables.
# Get a key: https://aistudio.google.com/apikey (no card required on free tier limits)
GEMINI_API_KEY=your_key_here

# Optional: pin one model (otherwise the API tries gemini-2.5-flash → gemini-2.5-flash-lite → gemini-2.0-flash).
# List names your key supports: curl "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY"
# GEMINI_MODEL=gemini-2.5-flash
